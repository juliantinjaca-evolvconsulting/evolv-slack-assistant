{
  "display_information": {
    "name": "Sales Assistant",
    "description": "Query sales data using natural language with Snowflake Cortex",
    "background_color": "#D15635"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "Sales Assistant",
      "always_online": true
    },
    "assistant_view": {
      "assistant_description": "Ask me about sales, opportunities, pipeline, leads and more. I can show you charts and tables with the data.",
      "suggested_prompts": []
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "assistant:write",
        "channels:join",
        "im:history",
        "im:read",
        "im:write",
        "channels:history",
        "groups:history",
        "chat:write",
        "files:write",
        "usergroups:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "assistant_thread_context_changed",
        "assistant_thread_started",
        "message.im",
        "message.channels",
        "message.groups"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
